# ==============================================================================
# AWSFinOps Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit real credentials to version control.
# ==============================================================================

# Application
APP_NAME=AWSFinOps

# Logger (see internal/utilities/logger.go)
LOG_LEVEL=INFO
CLOUDWATCH_MODE=false

# Worker (local mode only)
# WORKER_INTERVAL: 本地循环模式的执行间隔，支持 "30s" / "5m" / "3h" 或纯秒数 "60"
# WORKER_ONCE:     设为 true 时仅执行一次后退出（适合调试和 CI/CD）
WORKER_INTERVAL=6h
WORKER_ONCE=false

# AWS Credentials & Billing
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BILLING_BUCKET=
AWS_ACCOUNT_ID=123456789012

# Report Export
# 是否在每次运行后生成报告文件（PDF/JSON/CSV）
EXPORT_REPORT=true
# 报告输出目录（相对或绝对路径）
REPORT_OUTPUT_DIR=./reports
# 是否导出 PDF（高管报告，带水印）
EXPORT_PDF=true
# 是否导出 JSON（开发者格式）
EXPORT_JSON=true
# 是否导出 CSV（财务格式）
EXPORT_CSV=true

# Broadcast: Weixin (WeChat Work Bot)
WEIXIN_BOT_TOKEN=
WEIXIN_CHAT_ID=

# Broadcast: Feishu (Lark)
FEISHU_BOT_TOKEN=
FEISHU_CHAT_ID=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_ENCRYPT_KEY=
FEISHU_APP_VERIFY_TOKEN=

# Broadcast: DingDing (DingTalk)
DINGTALK_BOT_TOKEN=
DINGTALK_SECRET=

# Broadcast: Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Broadcast: Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Broadcast: Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Broadcast: Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
