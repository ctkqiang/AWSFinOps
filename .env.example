# ==============================================================================
# AWSFinOps Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit real credentials to version control.
# ==============================================================================

# Application
APP_NAME=AWSFinOps
APP_HOST=0.0.0.0
APP_PORT=8888

# Logger (see internal/utilities/logger.go)
LOG_LEVEL=INFO
CLOUDWATCH_MODE=false

# AWS Credentials & Billing
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BILLING_BUCKET=

# Broadcast: Weixin (WeChat Work Bot)
WEIXIN_BOT_TOKEN=
WEIXIN_CHAT_ID=

# Broadcast: Feishu (Lark)
FEISHU_BOT_TOKEN=
FEISHU_CHAT_ID=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_ENCRYPT_KEY=
FEISHU_APP_VERIFY_TOKEN=

# Broadcast: DingDing (DingTalk)
DINGTALK_BOT_TOKEN=
DINGTALK_SECRET=

# Broadcast: Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Broadcast: Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Broadcast: Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Broadcast: Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
